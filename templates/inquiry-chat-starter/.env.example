# Alle Werte pro Kundenprojekt setzen. Niemals echte Secrets in das Template schreiben.
INQUIRY_FROM_EMAIL=
INQUIRY_FROM_NAME=
INQUIRY_TO_EMAIL=
INQUIRY_ALLOWED_ORIGIN=https://example.com
FORM_TOKEN_SECRET=

