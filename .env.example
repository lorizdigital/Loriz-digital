# Brevo Transactional API (server-only)
BREVO_API_KEY=
PROJECT_INQUIRY_FROM_EMAIL=anfragen@send.loriz.digital
PROJECT_INQUIRY_FROM_NAME=Loriz Digital
PROJECT_INQUIRY_TO_EMAIL=hallo@loriz.digital

# Request validation (server-only; use a random secret with at least 32 bytes)
FORM_TOKEN_SECRET=
PROJECT_INQUIRY_ALLOWED_ORIGIN=https://loriz.digital

# Cloudflare Turnstile (public site key; required during the production build)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile (server-only runtime variables)
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=loriz.digital
